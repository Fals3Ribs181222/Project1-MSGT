        async function deleteTestimonial(id, mediaUrl) {
            if (!confirm('Are you sure you want to delete this testimonial?')) return;

            try {
                // 1. Delete from Storage if media exists
                if (mediaUrl) {
                    const filePath = mediaUrl.split('/').pop();
                    await supabaseClient.storage.from('testimonials').remove([`testimonials/${filePath}`]);
                }

                // 2. Delete from Database
                const { error } = await supabaseClient.from('testimonials').delete().eq('id', id);
                if (error) throw error;

                loadTestimonials();
            } catch (err) {
                console.error('Delete error:', err);
                alert('Failed to delete: ' + err.message);
            }
        }

        document.getElementById('btnRefreshTestimonials').addEventListener('click', loadTestimonials);

        // Pill Toggle for Testimonials
        const pillViewTestim = document.getElementById('pillViewTestimonials');
        const pillAddTestim = document.getElementById('pillAddTestimonial');
        const testimListContainer = document.getElementById('testimonialsListContainer');
        const addTestimContainer = document.getElementById('addTestimonialContainer');
        const btnRefreshTestim = document.getElementById('btnRefreshTestimonials');

        pillViewTestim.addEventListener('click', () => {
            pillViewTestim.classList.add('pill-toggle__btn--active');
            pillAddTestim.classList.remove('pill-toggle__btn--active');
            testimListContainer.style.display = 'block';
            addTestimContainer.style.display = 'none';
            btnRefreshTestim.style.display = 'inline-block';
        });

        pillAddTestim.addEventListener('click', () => {
            pillAddTestim.classList.add('pill-toggle__btn--active');
            pillViewTestim.classList.remove('pill-toggle__btn--active');
            addTestimContainer.style.display = 'block';
            testimListContainer.style.display = 'none';
            btnRefreshTestim.style.display = 'none';
        });

