<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Teacher Dashboard — manage students, materials, tests, and announcements.">
    <title>Teacher Dashboard | Mitesh Sir's Group Tuitions</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="css/styles.css">
</head>

<body class="is-home-active">
    <nav class="navbar" aria-label="Main navigation">
        <div class="container navbar__container">
            <a href="index.html" class="navbar__logo">Mitesh Sir's Group Tuitions</a>
            <ul class="navbar__links">
                <li><a href="index.html" class="navbar__link">Home</a></li>
                <li><a href="testimonials.html" class="navbar__link">Testimonials</a></li>
                <li><a href="results.html" class="navbar__link">Results</a></li>
            </ul>
        </div>
    </nav>

    <main class="container section">
        <header class="welcome">
            <h1>Welcome, <span class="welcome__name" id="teacherName">Teacher</span>!</h1>
            <p class="welcome__sub">Teacher Portal - Manage study materials and announcements.</p>
        </header>


        <div class="panels-container">
            <div class="back-to-home-container" style="margin-bottom: 2rem; display: none;">
                <button class="btn btn--outline btn--sm" id="btnBackToHome">← Back to Overview</button>
            </div>

            <!-- Home Panel -->
            <section class="panel tabs__panel tabs__panel--active" id="panel-home" role="tabpanel" aria-label="Home">
                <header class="panel__header" style="margin-bottom: 2rem;">
                    <h2>Dashboard Overview</h2>
                </header>
                <div class="landing-grid">
                    <button class="landing-pill" data-target="panel-students">
                        <span class="landing-pill__icon">🎓</span>
                        <span class="landing-pill__text">Students</span>
                    </button>
                    <button class="landing-pill" data-target="panel-attendance">
                        <span class="landing-pill__icon">✅</span>
                        <span class="landing-pill__text">Attendance</span>
                    </button>
                    <button class="landing-pill" data-target="panel-upload">
                        <span class="landing-pill__icon">📚</span>
                        <span class="landing-pill__text">Materials</span>
                    </button>
                    <button class="landing-pill" data-target="panel-test">
                        <span class="landing-pill__icon">📝</span>
                        <span class="landing-pill__text">Tests</span>
                    </button>
                    <button class="landing-pill" data-target="panel-announcement">
                        <span class="landing-pill__icon">📢</span>
                        <span class="landing-pill__text">Announcements</span>
                    </button>
                    <button class="landing-pill" data-target="panel-batches">
                        <span class="landing-pill__icon">🧑‍🤝‍🧑</span>
                        <span class="landing-pill__text">Batches</span>
                    </button>
                    <button class="landing-pill" data-target="panel-schedule">
                        <span class="landing-pill__icon">📅</span>
                        <span class="landing-pill__text">Schedule</span>
                    </button>
                    <button class="landing-pill" data-target="panel-board-results">
                        <span class="landing-pill__icon">🏆</span>
                        <span class="landing-pill__text">Board Results</span>
                    </button>
                    <button class="landing-pill" data-target="panel-testimonials">
                        <span class="landing-pill__icon">💬</span>
                        <span class="landing-pill__text">Testimonials</span>
                    </button>
                </div>
            </section>

            <!-- Upload Material Panel -->
            <section class="panel tabs__panel" id="panel-upload" role="tabpanel" aria-label="Materials">
                <header class="panel__header">
                    <h2>Manage Materials</h2>
                    <div class="pill-toggle">
                        <button class="pill-toggle__btn pill-toggle__btn--active" id="pillViewMaterials">Materials
                            List</button>
                        <button class="pill-toggle__btn" id="pillAddUpload">+ Upload New</button>
                    </div>
                </header>

                <!-- Materials List Container (default view) -->
                <div id="materialsListContainer">
                    <div id="materialsListStatus" class="status"></div>
                    <div class="table-wrap">
                        <table id="materialsTable" aria-label="Materials list">
                            <thead>
                                <tr>
                                    <th scope="col">Title</th>
                                    <th scope="col">Subject</th>
                                    <th scope="col">Grade</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Uploaded By</th>
                                    <th scope="col">Link</th>
                                </tr>
                            </thead>
                            <tbody id="materialsTableBody">
                                <tr>
                                    <td colspan="6" class="loading-text">Loading materials...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-right">
                        <button class="btn btn--primary btn--sm" id="btnRefreshMaterials">Refresh List</button>
                    </div>
                </div>

                <!-- Upload Form Container (loaded via fetch) -->
                <div id="addUploadContainer" class="panel__divider">
                    <div class="loading-text">Loading component...</div>
                </div>
            </section>

            <!-- Announcements Panel -->
            <section class="panel tabs__panel" id="panel-announcement" role="tabpanel" aria-label="Announcements">
                <header class="panel__header">
                    <h2>Manage Announcements</h2>
                    <div class="pill-toggle">
                        <button class="pill-toggle__btn pill-toggle__btn--active"
                            id="pillViewAnnouncements">Announcements List</button>
                        <button class="pill-toggle__btn" id="pillAddAnnouncement">+ Post New</button>
                    </div>
                </header>

                <!-- Announcements List Container (default view) -->
                <div id="announcementsListContainer">
                    <div id="announcementsListStatus" class="status"></div>
                    <div class="table-wrap">
                        <table id="announcementsTable" aria-label="Announcements list">
                            <thead>
                                <tr>
                                    <th scope="col">Title</th>
                                    <th scope="col">Grade</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Posted By</th>
                                </tr>
                            </thead>
                            <tbody id="announcementsTableBody">
                                <tr>
                                    <td colspan="4" class="loading-text">Loading announcements...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-right">
                        <button class="btn btn--primary btn--sm" id="btnRefreshAnnouncements">Refresh List</button>
                    </div>
                </div>

                <!-- Post Announcement Form Container (loaded via fetch) -->
                <div id="addAnnouncementContainer" class="panel__divider">
                    <div class="loading-text">Loading component...</div>
                </div>
            </section>

            <!-- Tests Panel -->
            <section class="panel tabs__panel" id="panel-test" role="tabpanel" aria-label="Tests">
                <header class="panel__header">
                    <h2>Manage Tests</h2>
                    <div class="pill-toggle">
                        <button class="pill-toggle__btn pill-toggle__btn--active" id="pillViewTests">Tests List</button>
                        <button class="pill-toggle__btn" id="pillAddTest">+ Schedule New</button>
                    </div>
                </header>

                <!-- Tests List Container (default view) -->
                <div id="testsListContainer">
                    <div id="testsListStatus" class="status"></div>
                    <div class="table-wrap">
                        <table id="testsListTable" aria-label="Tests list">
                            <thead>
                                <tr>
                                    <th scope="col">Title</th>
                                    <th scope="col">Subject</th>
                                    <th scope="col">Grade</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Max Marks</th>
                                    <th scope="col">Scheduled By</th>
                                    <th scope="col">Action</th>
                                </tr>
                            </thead>
                            <tbody id="testsListTableBody">
                                <tr>
                                    <td colspan="7" class="loading-text">Loading tests...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-right">
                        <button class="btn btn--primary btn--sm" id="btnRefreshTestsList">Refresh List</button>
                    </div>
                </div>

                <!-- Schedule Test Form Container (loaded via fetch) -->
                <div id="addTestContainer" class="panel__divider">
                    <div class="loading-text">Loading component...</div>
                </div>
            </section>

            <!-- Manage Students Panel -->
            <section class="panel tabs__panel" id="panel-students" role="tabpanel" aria-label="Students">
                <header class="panel__header">
                    <h2>Manage Students</h2>
                    <div class="pill-toggle">
                        <button class="pill-toggle__btn pill-toggle__btn--active" id="pillViewStudents">Student
                            List</button>
                        <button class="pill-toggle__btn" id="pillAddStudent">+ Add New</button>
                    </div>
                </header>

                <!-- View Container -->
                <div id="studentsListContainer">
                    <div id="studentsListStatus" class="status"></div>

                    <!-- Search & Filter Toolbar -->
                    <div class="students-toolbar">
                        <input type="text" class="students-toolbar__search" id="studentSearchInput"
                            placeholder="🔍 Search by name or username...">
                        <select class="students-toolbar__filter" id="studentGradeFilter">
                            <option value="">All Grades</option>
                            <option value="11th">11th</option>
                            <option value="12th">12th</option>
                        </select>
                        <select class="students-toolbar__filter" id="studentSubjectFilter">
                            <option value="">All Subjects</option>
                            <option value="Accounts">Accounts</option>
                            <option value="Commerce">Commerce</option>
                        </select>
                        <span class="students-toolbar__count" id="studentsCount"></span>
                    </div>

                    <div class="table-wrap">
                        <table id="studentsTable" aria-label="Students list">
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Username</th>
                                    <th scope="col">Grade</th>
                                    <th scope="col">Subjects</th>
                                    <th scope="col">Action</th>
                                </tr>
                            </thead>
                            <tbody id="studentsTableBody">
                                <tr>
                                    <td colspan="5" class="loading-text">Loading students...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-right">
                        <button class="btn btn--primary btn--sm" id="btnRefreshStudents">Refresh List</button>
                    </div>
                </div>

                <!-- Add Container -->
                <div id="addStudentContainer" class="panel__divider">
                    <div class="loading-text">Loading component...</div>
                </div>

                <!-- Student Detail View -->
                <div id="studentDetailContainer" class="student-detail" style="display:none;">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
                        <button class="btn btn--outline btn--sm" id="btnBackToStudents">Back to Students</button>
                        <button class="btn btn--danger btn--sm" id="btnDeleteStudentDetail">Delete Student</button>
                    </div>

                    <div class="panel__header">
                        <h2>Profile Information</h2>
                    </div>

                    <div class="profile-card"
                        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; background: var(--surface-bg); padding: 1.5rem; border-radius: var(--radius-lg); border: 1px solid var(--border-light); margin-bottom: 2rem;">
                        <div>
                            <p class="stat-card__label" style="margin-bottom: 0.25rem;">Name</p>
                            <p class="stat-card__value" id="studentDetailName" style="font-size: 1.25rem;">-</p>
                        </div>
                        <div>
                            <p class="stat-card__label" style="margin-bottom: 0.25rem;">Username / ID</p>
                            <p class="stat-card__value" id="studentDetailUsername" style="font-size: 1.25rem;">-</p>
                        </div>
                        <div>
                            <p class="stat-card__label" style="margin-bottom: 0.25rem;">Password</p>
                            <p class="stat-card__value" id="studentDetailPassword" style="font-size: 1.25rem;">••••••••
                            </p>
                        </div>
                        <div>
                            <p class="stat-card__label" style="margin-bottom: 0.25rem;">Grade</p>
                            <p class="stat-card__value" id="studentDetailGrade" style="font-size: 1.25rem;">-</p>
                        </div>
                        <div>
                            <p class="stat-card__label" style="margin-bottom: 0.25rem;">Subjects</p>
                            <p class="stat-card__value" id="studentDetailSubjects" style="font-size: 1.25rem;">-</p>
                        </div>
                    </div>

                    <!-- Attendance Stats -->
                    <div class="student-detail__stats" id="studentDetailStats">
                        <div class="student-detail__stat">
                            <div class="student-detail__stat-value" id="sdTotalClasses">-</div>
                            <div class="student-detail__stat-label">Total Classes</div>
                        </div>
                        <div class="student-detail__stat">
                            <div class="student-detail__stat-value student-detail__stat-value--green" id="sdPresent">-
                            </div>
                            <div class="student-detail__stat-label">Present</div>
                        </div>
                        <div class="student-detail__stat">
                            <div class="student-detail__stat-value student-detail__stat-value--red" id="sdAbsent">-
                            </div>
                            <div class="student-detail__stat-label">Absent</div>
                        </div>
                        <div class="student-detail__stat">
                            <div class="student-detail__stat-value student-detail__stat-value--amber" id="sdLate">-
                            </div>
                            <div class="student-detail__stat-label">Late</div>
                        </div>
                        <div class="student-detail__stat">
                            <div class="student-detail__stat-value" id="sdAttendanceRate">-</div>
                            <div class="student-detail__stat-label">Attendance %</div>
                        </div>
                    </div>

                    <!-- Batch Memberships -->
                    <div class="panel__header">
                        <h2>Batch Memberships</h2>
                    </div>
                    <div class="table-wrap">
                        <table id="studentBatchesTable">
                            <thead>
                                <tr>
                                    <th scope="col">Batch Name</th>
                                    <th scope="col">Subject</th>
                                    <th scope="col">Grade</th>
                                    <th scope="col">Schedule</th>
                                </tr>
                            </thead>
                            <tbody id="studentBatchesBody">
                                <tr>
                                    <td colspan="4" class="loading-text">Loading...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Test Scores -->
                <div class="panel__header">
                    <h2>Attendance Summary</h2>
                </div>
                <div class="table-wrap">
                    <table id="studentMarksTable">
                        <thead>
                            <tr>
                                <th scope="col">Test</th>
                                <th scope="col">Subject</th>
                                <th scope="col">Marks</th>
                                <th scope="col">Max</th>
                                <th scope="col">Date</th>
                            </tr>
                        </thead>
                        <tbody id="studentMarksBody">
                            <tr>
                                <td colspan="5" class="loading-text">Loading...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
        </div>
        </div>
        </section>

        <!-- Attendance Panel -->
        <section class="panel tabs__panel" id="panel-attendance" role="tabpanel" aria-label="Attendance">
            <header class="panel__header">
                <h2>Manage Attendance</h2>
                <div class="pill-toggle" id="attendanceHeaderActions" style="display:none;">
                    <button class="pill-toggle__btn" id="btnSwitchClassAttendance">← Switch Class</button>
                </div>
            </header>

            <!-- Pre-Selection Container -->
            <div id="attendancePreSelectionContainer">
                <p class="text-muted" style="margin-bottom: 1.5rem;">Select a class scheduled for today to mark
                    attendance.</p>
                <div id="todaysClassesGrid" class="classes-grid"
                    style="display:grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
                    <div class="loading-text">Loading today's classes...</div>
                </div>
            </div>

            <!-- Grid-Based Attendance Container -->
            <div id="attendanceGridContainer" style="display:none;">
                <div class="attendance-topbar" style="margin-bottom: 1.5rem;">
                    <h3 id="attendanceClassName" style="font-size: 1.25rem;">Class Name</h3>
                    <p id="attendanceClassMeta" class="text-muted">Batch • Time</p>
                </div>

                <div class="table-wrap">
                    <table id="attendanceTable" class="attendance-table" aria-label="Attendance list">
                        <thead>
                            <tr>
                                <th scope="col">Student Name</th>
                                <th scope="col" style="text-align: right;">Status</th>
                            </tr>
                        </thead>
                        <tbody id="attendanceTableBody">
                            <tr>
                                <td colspan="2" class="loading-text">Loading roster...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="form__actions"
                    style="margin-top: 1.5rem; display: flex; gap: 0.75rem; align-items: center;">
                    <button class="btn btn--outline" id="btnAddGuest" style="font-size: 0.9rem;">+ Add
                        Student</button>
                    <button class="btn btn--outline" id="btnMarkAllPresent">Mark All Present</button>
                    <button class="btn btn--primary" id="btnSaveAttendance">Save Attendance</button>
                </div>

                <!-- Add Guest / Transfer Form -->
                <div id="addGuestForm"
                    style="display:none; margin-top: 1.5rem; padding: 1.25rem; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: var(--radius-lg); backdrop-filter: blur(16px);">
                    <h4 style="margin: 0 0 1rem 0; color: var(--primary);">Cross-Batch Transfer</h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="form__group">
                            <label class="form__label" for="guestBatchSelect">From Batch</label>
                            <select class="form__control" id="guestBatchSelect">
                                <option value="">Select a batch...</option>
                            </select>
                        </div>
                        <div class="form__group">
                            <label class="form__label" for="guestStudentSelect">Student</label>
                            <select class="form__control" id="guestStudentSelect" disabled>
                                <option value="">Pick a batch first...</option>
                            </select>
                        </div>
                    </div>
                    <div class="form__actions" style="margin-top: 1rem; justify-content: flex-end; gap: 0.75rem;">
                        <button class="btn btn--outline" id="btnCancelGuest">Cancel</button>
                        <button class="btn btn--primary" id="btnConfirmGuest">Add to Roster</button>
                    </div>
                    <div id="guestStatus" class="status" style="display:none; margin-top: 0.75rem;"></div>
                </div>

                <div id="attendanceSaveStatus" class="status" style="display:none; margin-top: 1rem;"></div>
            </div>
        </section>

        <!-- Board Results Panel -->
        <section class="panel tabs__panel" id="panel-board-results" role="tabpanel" aria-label="Board Results">
            <header class="panel__header">
                <h2>Manage Board Results</h2>
                <div class="pill-toggle">
                    <button class="pill-toggle__btn pill-toggle__btn--active" id="pillViewBoardResults">Results
                        List</button>
                    <button class="pill-toggle__btn" id="pillAddBoardResult">+ Add New</button>
                </div>
            </header>

            <!-- Board Results List Container (default view) -->
            <div id="boardResultsListContainer">
                <div id="boardResultsListStatus" class="status"></div>
                <div class="table-wrap">
                    <table id="boardResultsTable" aria-label="Board results list">
                        <thead>
                            <tr>
                                <th scope="col">Student Name</th>
                                <th scope="col">Subject</th>
                                <th scope="col">Marks</th>
                                <th scope="col">Max Marks</th>
                                <th scope="col">Year</th>
                                <th scope="col">Action</th>
                            </tr>
                        </thead>
                        <tbody id="boardResultsTableBody">
                            <tr>
                                <td colspan="6" class="loading-text">Loading board results...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="text-right">
                    <button class="btn btn--primary btn--sm" id="btnRefreshBoardResults">Refresh List</button>
                </div>
            </div>

            <!-- Add Board Result Form Container (loaded via fetch) -->
            <div id="addBoardResultContainer" class="panel__divider">
                <div class="loading-text">Loading component...</div>
            </div>
        </section>

        <!-- Testimonials Panel -->
        <section class="panel tabs__panel" id="panel-testimonials" role="tabpanel" aria-label="Testimonials">
            <header class="panel__header">
                <h2>Manage Testimonials</h2>
                <div class="pill-toggle">
                    <button class="pill-toggle__btn pill-toggle__btn--active" id="pillViewTestimonials">Testimonials
                        List</button>
                    <button class="pill-toggle__btn" id="pillAddTestimonial">+ Add New</button>
                </div>
            </header>

            <!-- Testimonials List Container (default view) -->
            <div id="testimonialsListContainer">
                <div id="testimonialsListStatus" class="status"></div>
                <div class="table-wrap">
                    <table id="testimonialsTable" aria-label="Testimonials list">
                        <thead>
                            <tr>
                                <th scope="col">Student Name</th>
                                <th scope="col">Subject</th>
                                <th scope="col">Year</th>
                                <th scope="col">Testimonial Text</th>
                                <th scope="col">Media</th>
                                <th scope="col">Date Added</th>
                                <th scope="col">Action</th>
                            </tr>
                        </thead>
                        <tbody id="testimonialsTableBody">
                            <tr>
                                <td colspan="7" class="loading-text">Loading testimonials...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="text-right">
                    <button class="btn btn--primary btn--sm" id="btnRefreshTestimonials">Refresh List</button>
                </div>
            </div>

            <!-- Add Testimonial Form Container (loaded via fetch) -->
            <div id="addTestimonialContainer" class="panel__divider">
                <div class="loading-text">Loading component...</div>
            </div>
        </section>

        <!-- Batches Panel -->
        <section class="panel tabs__panel" id="panel-batches" role="tabpanel" aria-label="Batches">
            <header class="panel__header">
                <h2>Manage Batches</h2>
                <div class="pill-toggle">
                    <button class="pill-toggle__btn pill-toggle__btn--active" id="pillViewBatches">Batch
                        List</button>
                    <button class="pill-toggle__btn" id="pillAddBatch">+ Create New</button>
                </div>
            </header>

            <!-- Batch List Container (default view) -->
            <div id="batchesListContainer">
                <div id="batchesListStatus" class="status"></div>
                <div class="table-wrap">
                    <table id="batchesTable" aria-label="Batches list">
                        <thead>
                            <tr>
                                <th scope="col">Batch Name</th>
                                <th scope="col">Subject</th>
                                <th scope="col">Grade</th>
                                <th scope="col">Schedule</th>
                                <th scope="col">Students</th>
                                <th scope="col">Action</th>
                            </tr>
                        </thead>
                        <tbody id="batchesTableBody">
                            <tr>
                                <td colspan="6" class="loading-text">Loading batches...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="text-right">
                    <button class="btn btn--primary btn--sm" id="btnRefreshBatches">Refresh List</button>
                </div>
            </div>

            <!-- Create Batch Form Container (loaded via fetch) -->
            <div id="addBatchContainer" class="panel__divider">
                <div class="loading-text">Loading component...</div>
            </div>

            <!-- Batch Detail Overlay -->
            <div id="batchDetailContainer" class="batch-detail" style="display:none;">
                <div class="batch-detail__header">
                    <button class="btn btn--outline btn--sm" id="btnBackToBatches">← Back to Batches</button>
                    <h3 id="batchDetailName">Batch Name</h3>
                    <p id="batchDetailMeta" class="batch-detail__meta"></p>
                </div>

                <div class="batch-detail__body">
                    <!-- Current Members -->
                    <div class="batch-detail__members">
                        <h4>Current Members <span class="badge" id="batchMemberCount">0</span></h4>
                        <div id="batchDetailStatus" class="status" style="display:none;"></div>
                        <div class="table-wrap">
                            <table id="batchMembersTable">
                                <thead>
                                    <tr>
                                        <th scope="col">Name</th>
                                        <th scope="col">Username</th>
                                        <th scope="col">Grade</th>
                                        <th scope="col">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="batchMembersBody">
                                    <tr>
                                        <td colspan="4" class="loading-text">Loading members...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Student Picker -->
                    <div class="student-picker">
                        <h4>Add Students</h4>
                        <input type="text" id="studentPickerSearch" class="form__control student-picker__search"
                            placeholder="Search students by name...">
                        <div class="student-picker__list" id="studentPickerList">
                            <p class="loading-text">Loading students...</p>
                        </div>
                        <div class="student-picker__actions">
                            <button class="btn btn--primary btn--sm" id="btnAddSelectedStudents">Add
                                Selected</button>
                            <span id="selectedCount" class="student-picker__count">0 selected</span>
                        </div>
                    </div>
                </div>

                <div class="batch-detail__footer">
                    <button class="btn btn--danger btn--sm" id="btnDeleteBatch">Delete This Batch</button>
                </div>
            </div>
            </div>
        </section>

        <!-- Schedule Panel -->
        <section class="panel tabs__panel" id="panel-schedule" role="tabpanel" aria-label="Schedule">
            <header class="panel__header">
                <h2>Class Schedule</h2>
                <div class="pill-toggle">
                    <button class="pill-toggle__btn pill-toggle__btn--active" id="pillViewCalendar">Calendar</button>
                    <button class="pill-toggle__btn" id="pillAddClass">+ Add Class</button>
                </div>
            </header>

            <!-- Calendar Container -->
            <div id="calendarContainer">
                <div class="calendar">
                    <div class="calendar__header">
                        <button class="btn btn--outline btn--sm" id="btnPrevMonth">← Prev</button>
                        <h3 id="calendarMonthYear" class="calendar__title">Month Year</h3>
                        <button class="btn btn--outline btn--sm" id="btnNextMonth">Next →</button>
                    </div>
                    <div class="calendar__grid" id="calendarGrid">
                        <div class="calendar__day-header">Mon</div>
                        <div class="calendar__day-header">Tue</div>
                        <div class="calendar__day-header">Wed</div>
                        <div class="calendar__day-header">Thu</div>
                        <div class="calendar__day-header">Fri</div>
                        <div class="calendar__day-header">Sat</div>
                        <div class="calendar__day-header">Sun</div>
                        <!-- Days generated by JS -->
                    </div>
                </div>
            </div>

            <!-- Add Class Container -->
            <div id="addClassContainer" class="panel__divider">
                <div class="loading-text">Loading component...</div>
            </div>
        </section>
        </div>
    </main>

    <!-- Class Detail Modal Overlay -->
    <div id="classModalOverlay" class="modal-overlay" style="display:none;">
        <div class="class-modal">
            <header class="class-modal__header">
                <div>
                    <h3 id="modalClassTitle">Class Title</h3>
                    <p id="modalClassMeta" class="class-modal__meta">Time • Batch Name • Type</p>
                </div>
                <button class="class-modal__close" id="btnModalClose">×</button>
            </header>
            <div class="class-modal__content">
                <div id="modalClassNotes" class="class-modal__notes" style="display:none;"></div>
                <h4>Enrolled Students (<span id="modalStudentCount">0</span>)</h4>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Grade</th>
                            </tr>
                        </thead>
                        <tbody id="modalStudentList">
                            <tr>
                                <td colspan="2" class="loading-text">Loading...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <footer class="class-modal__footer">
                <button class="btn btn--danger btn--sm" id="btnModalDeleteClass">Delete Class</button>
            </footer>
        </div>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="footer__bottom">
                <p>&copy; 2026 Mitesh Sir's Group Tuitions. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="js/config.js"></script>
    <script src="js/app.js"></script>
    <script>
        // Require teacher role
        const user = auth.requireRole('teacher');
        document.getElementById('teacherName').textContent = user.name;

        // Load Materials List handler
        async function loadMaterials() {
            const tbody = document.getElementById('materialsTableBody');
            const status = document.getElementById('materialsListStatus');
            const btnRefresh = document.getElementById('btnRefreshMaterials');

            if (!tbody || !status || !btnRefresh) return;

            btnRefresh.disabled = true;
            btnRefresh.textContent = 'Refreshing...';
            status.style.display = 'none';
            tbody.innerHTML = '<tr><td colspan="6" class="loading-text">Loading materials...</td></tr>';

            const response = await api.get('files');

            btnRefresh.disabled = false;
            btnRefresh.textContent = 'Refresh List';

            if (response.success) {
                if (response.data && response.data.length > 0) {
                    tbody.innerHTML = response.data.map(file => `
                        <tr class="data-table__row">
                            <td class="data-table__td--main">${file.title || '-'}</td>
                            <td class="data-table__td">${file.subject || '-'}</td>
                            <td class="data-table__td">${file.grade || 'All'}</td>
                            <td class="data-table__td">${file.created_at ? new Date(file.created_at).toLocaleDateString() : '-'}</td>
                            <td class="data-table__td">${file.uploaded_by || '-'}</td>
                            <td class="data-table__td"><a href="${file.file_url || '#'}" target="_blank" class="navbar__link">View</a></td>
                        </tr>
                    `).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="6" class="loading-text">No materials uploaded yet.</td></tr>';
                }
            } else {
                tbody.innerHTML = '';
                status.textContent = response.error || 'Failed to load materials.';
                status.className = 'status status--error';
                status.style.display = 'block';
            }
        }

        document.getElementById('btnRefreshMaterials').addEventListener('click', loadMaterials);

        // Pill Toggle Logic for Upload Tab
        const pillViewMaterials = document.getElementById('pillViewMaterials');
        const pillAddUpload = document.getElementById('pillAddUpload');
        const materialsListContainer = document.getElementById('materialsListContainer');
        const addUploadContainer = document.getElementById('addUploadContainer');
        const btnRefreshMaterials = document.getElementById('btnRefreshMaterials');

        pillViewMaterials.addEventListener('click', () => {
            pillViewMaterials.classList.add('pill-toggle__btn--active');
            pillAddUpload.classList.remove('pill-toggle__btn--active');
            materialsListContainer.style.display = 'block';
            addUploadContainer.style.display = 'none';
            btnRefreshMaterials.style.display = 'inline-block';
        });

        pillAddUpload.addEventListener('click', () => {
            pillAddUpload.classList.add('pill-toggle__btn--active');
            pillViewMaterials.classList.remove('pill-toggle__btn--active');
            addUploadContainer.style.display = 'block';
            materialsListContainer.style.display = 'none';
            btnRefreshMaterials.style.display = 'none';
        });

        // Load Upload Component
        async function loadUploadComponent() {
            try {
                const response = await fetch('components/add_upload.html');
                if (response.ok) {
                    const html = await response.text();
                    document.getElementById('addUploadContainer').innerHTML = html;
                    attachUploadListeners();
                } else {
                    console.error('Failed to load upload component: HTTP Status', response.status);
                }
            } catch (err) {
                console.error('Error loading upload component:', err);
            }
        }

        function attachUploadListeners() {
            const form = document.getElementById('uploadForm');
            if (!form) return;

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = document.getElementById('btnUpload');
                const status = document.getElementById('uploadStatus');
                const fileInput = document.getElementById('fileInput');

                if (fileInput.files.length === 0) return;
                const file = fileInput.files[0];

                btn.disabled = true;
                btn.textContent = 'Uploading...';
                status.className = 'status';

                try {
                    // 1. Upload to Supabase Storage
                    const filePath = `materials/${Date.now()}_${file.name}`;
                    const { data: storageData, error: storageError } = await supabaseClient
                        .storage
                        .from('materials')
                        .upload(filePath, file);

                    if (storageError) throw storageError;

                    // 2. Get Public URL
                    const { data: { publicUrl } } = supabaseClient
                        .storage
                        .from('materials')
                        .getPublicUrl(filePath);

                    // 3. Insert into files table
                    const subjectCheckboxes = document.querySelectorAll('input[name="fileSubjects"]:checked');
                    const subjects = Array.from(subjectCheckboxes).map(cb => cb.value).join(', ');

                    const payload = {
                        title: document.getElementById('fileTitle').value,
                        subject: subjects,
                        grade: document.getElementById('fileGrade').value,
                        file_url: publicUrl,
                        uploaded_by: user.id
                    };

                    const response = await api.post('files', payload);

                    if (response.success) {
                        status.textContent = 'File uploaded successfully!';
                        status.className = 'status status--success';
                        e.target.reset();
                        if (typeof loadMaterials === 'function') loadMaterials();
                    } else {
                        throw new Error(response.error);
                    }
                } catch (err) {
                    console.error('Upload Error:', err);
                    status.textContent = err.message || 'Failed to upload.';
                    status.className = 'status status--error';
                } finally {
                    btn.disabled = false;
                    btn.textContent = 'Upload Material';
                }
            });
        }

        // ====== ANNOUNCEMENTS: List + Component ======
        async function loadAnnouncements() {
            const tbody = document.getElementById('announcementsTableBody');
            const status = document.getElementById('announcementsListStatus');
            const btnRefresh = document.getElementById('btnRefreshAnnouncements');

            if (!tbody || !status || !btnRefresh) return;

            btnRefresh.disabled = true;
            btnRefresh.textContent = 'Refreshing...';
            status.style.display = 'none';
            tbody.innerHTML = '<tr><td colspan="4" class="loading-text">Loading announcements...</td></tr>';

            const response = await api.get('announcements');

            btnRefresh.disabled = false;
            btnRefresh.textContent = 'Refresh List';

            if (response.success) {
                if (response.data && response.data.length > 0) {
                    tbody.innerHTML = response.data.reverse().map(ann => `
                        <tr class="data-table__row">
                            <td class="data-table__td--main">${ann.title || '-'}</td>
                            <td class="data-table__td">${ann.grade || 'All'}</td>
                            <td class="data-table__td">${ann.created_at ? new Date(ann.created_at).toLocaleDateString() : '-'}</td>
                            <td class="data-table__td">${ann.posted_by || '-'}</td>
                        </tr>
                    `).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="4" class="loading-text">No announcements posted yet.</td></tr>';
                }
            } else {
                tbody.innerHTML = '';
                status.textContent = response.error || 'Failed to load announcements.';
                status.className = 'status status--error';
                status.style.display = 'block';
            }
        }

        document.getElementById('btnRefreshAnnouncements').addEventListener('click', loadAnnouncements);

        // Pill Toggle for Announcements
        const pillViewAnn = document.getElementById('pillViewAnnouncements');
        const pillAddAnn = document.getElementById('pillAddAnnouncement');
        const annListContainer = document.getElementById('announcementsListContainer');
        const addAnnContainer = document.getElementById('addAnnouncementContainer');
        const btnRefreshAnn = document.getElementById('btnRefreshAnnouncements');

        pillViewAnn.addEventListener('click', () => {
            pillViewAnn.classList.add('pill-toggle__btn--active');
            pillAddAnn.classList.remove('pill-toggle__btn--active');
            annListContainer.style.display = 'block';
            addAnnContainer.style.display = 'none';
            btnRefreshAnn.style.display = 'inline-block';
        });

        pillAddAnn.addEventListener('click', () => {
            pillAddAnn.classList.add('pill-toggle__btn--active');
            pillViewAnn.classList.remove('pill-toggle__btn--active');
            addAnnContainer.style.display = 'block';
            annListContainer.style.display = 'none';
            btnRefreshAnn.style.display = 'none';
        });

        async function loadAnnouncementComponent() {
            try {
                const response = await fetch('components/add_announcement.html');
                if (response.ok) {
                    const html = await response.text();
                    document.getElementById('addAnnouncementContainer').innerHTML = html;
                    attachAnnouncementListeners();
                } else {
                    console.error('Failed to load announcement component: HTTP Status', response.status);
                }
            } catch (err) {
                console.error('Error loading announcement component:', err);
            }
        }

        function attachAnnouncementListeners() {
            const form = document.getElementById('noticeForm');
            if (!form) return;

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = document.getElementById('btnNotice');
                const status = document.getElementById('noticeStatus');

                btn.disabled = true;
                btn.textContent = 'Posting...';
                status.className = 'status';

                const response = await api.post('announcements', {
                    title: document.getElementById('noticeTitle').value,
                    message: document.getElementById('noticeMessage').value,
                    grade: document.getElementById('noticeGrade').value,
                    posted_by: user.id
                });

                btn.disabled = false;
                btn.textContent = 'Post Announcement';

                if (response.success) {
                    status.textContent = 'Announcement posted successfully!';
                    status.className = 'status status--success';
                    e.target.reset();
                    if (typeof loadAnnouncements === 'function') loadAnnouncements();
                } else {
                    status.textContent = response.error || 'Failed to post.';
                    status.className = 'status status--error';
                }
            });
        }

        // ====== TESTS: List + Component ======
        async function loadTestsList() {
            const tbody = document.getElementById('testsListTableBody');
            const status = document.getElementById('testsListStatus');
            const btnRefresh = document.getElementById('btnRefreshTestsList');

            if (!tbody || !status || !btnRefresh) return;

            btnRefresh.disabled = true;
            btnRefresh.textContent = 'Refreshing...';
            status.style.display = 'none';
            tbody.innerHTML = '<tr><td colspan="7" class="loading-text">Loading tests...</td></tr>';

            const response = await api.get('tests', {}, '*, profiles:scheduled_by(name)');

            btnRefresh.disabled = false;
            btnRefresh.textContent = 'Refresh List';

            if (response.success) {
                if (response.data && response.data.length > 0) {
                    tbody.innerHTML = response.data.reverse().map(test => {
                        const teacherName = test.profiles?.name || '-';
                        return `
                        <tr class="data-table__row">
                            <td class="data-table__td--main">${test.title || '-'}</td>
                            <td class="data-table__td">${test.subject || '-'}</td>
                            <td class="data-table__td">${test.grade || '-'}</td>
                            <td class="data-table__td">${test.date || '-'}</td>
                            <td class="data-table__td">${test.max_marks || '-'}</td>
                            <td class="data-table__td">${teacherName}</td>
                            <td class="data-table__td">
                                <a href="manage_marks.html?testId=${test.id}" class="btn btn--primary btn--sm">Manage Marks</a>
                            </td>
                        </tr>
                    `}).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="7" class="loading-text">No tests scheduled yet.</td></tr>';
                }
            } else {
                tbody.innerHTML = '';
                status.textContent = response.error || 'Failed to load tests.';
                status.className = 'status status--error';
                status.style.display = 'block';
            }
        }

        document.getElementById('btnRefreshTestsList').addEventListener('click', loadTestsList);

        // Pill Toggle for Tests
        const pillViewTests = document.getElementById('pillViewTests');
        const pillAddTest = document.getElementById('pillAddTest');
        const testsListContainer = document.getElementById('testsListContainer');
        const addTestContainer = document.getElementById('addTestContainer');
        const btnRefreshTestsList = document.getElementById('btnRefreshTestsList');

        pillViewTests.addEventListener('click', () => {
            pillViewTests.classList.add('pill-toggle__btn--active');
            pillAddTest.classList.remove('pill-toggle__btn--active');
            testsListContainer.style.display = 'block';
            addTestContainer.style.display = 'none';
            btnRefreshTestsList.style.display = 'inline-block';
        });

        pillAddTest.addEventListener('click', () => {
            pillAddTest.classList.add('pill-toggle__btn--active');
            pillViewTests.classList.remove('pill-toggle__btn--active');
            addTestContainer.style.display = 'block';
            testsListContainer.style.display = 'none';
            btnRefreshTestsList.style.display = 'none';
        });

        async function loadTestComponent() {
            try {
                const response = await fetch('components/add_test.html');
                if (response.ok) {
                    const html = await response.text();
                    document.getElementById('addTestContainer').innerHTML = html;
                    attachTestListeners();
                } else {
                    console.error('Failed to load test component: HTTP Status', response.status);
                }
            } catch (err) {
                console.error('Error loading test component:', err);
            }
        }

        function attachTestListeners() {
            const form = document.getElementById('testForm');
            if (!form) return;

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = document.getElementById('btnScheduleTest');
                const status = document.getElementById('testStatus');

                btn.disabled = true;
                btn.textContent = 'Scheduling...';
                status.className = 'status';

                const subjectCheckboxes = document.querySelectorAll('input[name="testSubjects"]:checked');
                const subjects = Array.from(subjectCheckboxes).map(cb => cb.value).join(', ');

                const response = await api.post('tests', {
                    title: document.getElementById('testTitle').value,
                    subject: subjects,
                    grade: document.getElementById('testGrade').value,
                    date: document.getElementById('testDate').value,
                    max_marks: document.getElementById('testMaxMarks').value,
                    scheduled_by: user.id
                });

                btn.disabled = false;
                btn.textContent = 'Schedule Test';

                if (response.success) {
                    status.textContent = 'Test scheduled successfully!';
                    status.className = 'status status--success';
                    e.target.reset();
                    if (typeof loadTestsList === 'function') loadTestsList();
                } else {
                    status.textContent = response.error || 'Failed to schedule.';
                    status.className = 'status status--error';
                }
            });
        }

        let currentTests = [];
        let allStudents = [];

        // ====== STUDENTS: Load, Render, Search, Filter, Delete, Detail ======

        // Load Students List handler
        async function loadStudents() {
            const tbody = document.getElementById('studentsTableBody');
            const status = document.getElementById('studentsListStatus');
            const btnRefresh = document.getElementById('btnRefreshStudents');

            if (!tbody || !status || !btnRefresh) return;

            btnRefresh.disabled = true;
            btnRefresh.textContent = 'Refreshing...';
            status.style.display = 'none';
            tbody.innerHTML = '<tr><td colspan="5" class="loading-text">Loading students...</td></tr>';

            const response = await api.get('profiles', { role: 'student' });

            btnRefresh.disabled = false;
            btnRefresh.textContent = 'Refresh List';

            if (response.success) {
                allStudents = response.data || [];
                filterStudents();
            } else {
                tbody.innerHTML = '';
                status.textContent = response.error || 'Failed to load students.';
                status.className = 'status status--error';
                status.style.display = 'block';
            }
        }

        // Render the students table from a filtered array
        function renderStudentsTable(students) {
            const tbody = document.getElementById('studentsTableBody');
            const countEl = document.getElementById('studentsCount');
            if (!tbody) return;

            // Update count
            if (countEl) {
                countEl.textContent = `Showing ${students.length} of ${allStudents.length}`;
            }

            if (students.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="loading-text">No students match your filters.</td></tr>';
                return;
            }

            tbody.innerHTML = students.map(student => `
                <tr class="data-table__row" data-student-id="${student.id}">
                    <td class="data-table__td--main">${student.name || '-'}</td>
                    <td class="data-table__td">${student.username || '-'}</td>
                    <td class="data-table__td">${student.grade || '-'}</td>
                    <td class="data-table__td">${student.subjects || '-'}</td>
                    <td class="data-table__td">
                        <button class="btn btn--primary btn--sm" data-action="detail" data-id="${student.id}">Manage Student</button>
                    </td>
                </tr>
            `).join('');
        }

        // Filter students based on search, grade, and subject
        function filterStudents() {
            const searchVal = (document.getElementById('studentSearchInput')?.value || '').toLowerCase();
            const gradeVal = document.getElementById('studentGradeFilter')?.value || '';
            const subjectVal = document.getElementById('studentSubjectFilter')?.value || '';

            let filtered = allStudents;

            if (searchVal) {
                filtered = filtered.filter(s =>
                    (s.name || '').toLowerCase().includes(searchVal) ||
                    (s.username || '').toLowerCase().includes(searchVal)
                );
            }

            if (gradeVal) {
                filtered = filtered.filter(s => s.grade === gradeVal);
            }

            if (subjectVal) {
                filtered = filtered.filter(s =>
                    (s.subjects || '').includes(subjectVal)
                );
            }

            renderStudentsTable(filtered);
        }

        // Attach filter event listeners
        const studentSearchInput = document.getElementById('studentSearchInput');
        const studentGradeFilter = document.getElementById('studentGradeFilter');
        const studentSubjectFilter = document.getElementById('studentSubjectFilter');

        if (studentSearchInput) studentSearchInput.addEventListener('input', filterStudents);
        if (studentGradeFilter) studentGradeFilter.addEventListener('change', filterStudents);
        if (studentSubjectFilter) studentSubjectFilter.addEventListener('change', filterStudents);

        document.getElementById('btnRefreshStudents').addEventListener('click', loadStudents);

        // ====== DELETE ======
        function showConfirmModal(title, message, onConfirm) {
            const overlay = document.createElement('div');
            overlay.className = 'confirm-overlay';
            overlay.innerHTML = `
                <div class="confirm-modal">
                    <h3>${title}</h3>
                    <p>${message}</p>
                    <div class="confirm-modal__actions">
                        <button class="btn btn--outline btn--sm" id="confirmCancel">Cancel</button>
                        <button class="btn btn--danger btn--sm" id="confirmOk">Delete</button>
                    </div>
                </div>
            `;
            document.body.appendChild(overlay);

            overlay.querySelector('#confirmCancel').addEventListener('click', () => overlay.remove());
            overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.remove(); });
            overlay.querySelector('#confirmOk').addEventListener('click', async () => {
                overlay.querySelector('#confirmOk').disabled = true;
                overlay.querySelector('#confirmOk').textContent = 'Deleting...';
                await onConfirm();
                overlay.remove();
            });
        }

        async function deleteStudent(studentId) {
            const student = allStudents.find(s => s.id === studentId);
            showConfirmModal(
                'Delete Student',
                `Are you sure you want to delete <strong>${student?.name || 'this student'}</strong>? This cannot be undone.`,
                async () => {
                    const resp = await api.delete('profiles', studentId);
                    if (resp.success) {
                        allStudents = allStudents.filter(s => s.id !== studentId);
                        filterStudents();
                    } else {
                        alert('Failed to delete: ' + (resp.error || 'Unknown error'));
                    }
                }
            );
        }

        // ====== STUDENT DETAIL VIEW ======
        async function showStudentDetail(studentId) {
            const student = allStudents.find(s => s.id === studentId);
            if (!student) return;

            // Hide list and add containers, show detail
            document.getElementById('studentsListContainer').style.display = 'none';
            document.getElementById('addStudentContainer').style.display = 'none';
            document.getElementById('studentDetailContainer').style.display = 'block';
            document.getElementById('btnRefreshStudents').style.display = 'none';

            // Set header info
            document.getElementById('studentDetailName').textContent = student.name || 'Unknown';
            document.getElementById('studentDetailUsername').textContent = student.username || '-';
            document.getElementById('studentDetailGrade').textContent = student.grade || '-';
            document.getElementById('studentDetailSubjects').textContent = student.subjects || '-';

            // Reset loading states
            document.getElementById('studentBatchesBody').innerHTML = '<tr><td colspan="4" class="loading-text">Loading batches...</td></tr>';
            document.getElementById('studentMarksBody').innerHTML = '<tr><td colspan="5" class="loading-text">Loading marks...</td></tr>';
            ['sdTotalClasses', 'sdPresent', 'sdAbsent', 'sdLate', 'sdAttendanceRate'].forEach(id => {
                document.getElementById(id).textContent = '...';
            });

            // Fetch batch memberships
            try {
                const { data: batchLinks } = await supabaseClient
                    .from('batch_students')
                    .select('batch_id')
                    .eq('student_id', studentId);

                const batchBody = document.getElementById('studentBatchesBody');
                if (batchLinks && batchLinks.length > 0) {
                    const batchIds = batchLinks.map(bl => bl.batch_id);
                    const { data: batches } = await supabaseClient
                        .from('batches')
                        .select('*')
                        .in('id', batchIds);

                    if (batches && batches.length > 0) {
                        batchBody.innerHTML = batches.map(b => `
                            <tr class="data-table__row">
                                <td class="data-table__td--main">${b.name || '-'}</td>
                                <td class="data-table__td">${b.subject || '-'}</td>
                                <td class="data-table__td">${b.grade || '-'}</td>
                                <td class="data-table__td">${b.schedule || '-'}</td>
                            </tr>
                        `).join('');
                    } else {
                        batchBody.innerHTML = '<tr><td colspan="4" class="student-detail__empty">No batches found.</td></tr>';
                    }
                } else {
                    batchBody.innerHTML = '<tr><td colspan="4" class="student-detail__empty">Not assigned to any batches.</td></tr>';
                }
            } catch (err) {
                console.error('Batch fetch error:', err);
                document.getElementById('studentBatchesBody').innerHTML = '<tr><td colspan="4" class="student-detail__empty">Error loading batches.</td></tr>';
            }

            // Fetch attendance records
            try {
                const { data: attendanceData } = await supabaseClient
                    .from('attendance')
                    .select('status')
                    .eq('student_id', studentId);

                const total = attendanceData?.length || 0;
                const present = attendanceData?.filter(a => a.status === 'present').length || 0;
                const absent = attendanceData?.filter(a => a.status === 'absent').length || 0;
                const late = attendanceData?.filter(a => a.status === 'late').length || 0;
                const rate = total > 0 ? Math.round(((present + late) / total) * 100) : 0;

                document.getElementById('sdTotalClasses').textContent = total;
                document.getElementById('sdPresent').textContent = present;
                document.getElementById('sdAbsent').textContent = absent;
                document.getElementById('sdLate').textContent = late;
                document.getElementById('sdAttendanceRate').textContent = total > 0 ? rate + '%' : 'N/A';
            } catch (err) {
                console.error('Attendance fetch error:', err);
            }

            // Fetch marks + tests
            try {
                const { data: marksData } = await supabaseClient
                    .from('marks')
                    .select('marks_obtained, test_id')
                    .eq('student_id', studentId);

                const marksBody = document.getElementById('studentMarksBody');

                if (marksData && marksData.length > 0) {
                    const testIds = [...new Set(marksData.map(m => m.test_id))];
                    const { data: testsData } = await supabaseClient
                        .from('tests')
                        .select('*')
                        .in('id', testIds);

                    const testMap = {};
                    (testsData || []).forEach(t => testMap[t.id] = t);

                    marksBody.innerHTML = marksData.map(m => {
                        const test = testMap[m.test_id] || {};
                        return `
                            <tr class="data-table__row">
                                <td class="data-table__td--main">${test.title || '-'}</td>
                                <td class="data-table__td">${test.subject || '-'}</td>
                                <td class="data-table__td"><strong>${m.marks_obtained || '-'}</strong></td>
                                <td class="data-table__td">${test.max_marks || '-'}</td>
                                <td class="data-table__td">${test.date ? new Date(test.date).toLocaleDateString() : '-'}</td>
                            </tr>
                        `;
                    }).join('');
                } else {
                    marksBody.innerHTML = '<tr><td colspan="5" class="student-detail__empty">No test scores recorded.</td></tr>';
                }
            } catch (err) {
                console.error('Marks fetch error:', err);
                document.getElementById('studentMarksBody').innerHTML = '<tr><td colspan="5" class="student-detail__empty">Error loading marks.</td></tr>';
            }
        }

        function hideStudentDetail() {
            document.getElementById('studentDetailContainer').style.display = 'none';
            document.getElementById('studentsListContainer').style.display = 'block';
            document.getElementById('btnRefreshStudents').style.display = 'inline-block';

            // Reset pill toggle
            const pillView = document.getElementById('pillViewStudents');
            const pillAdd = document.getElementById('pillAddStudent');
            if (pillView) pillView.classList.add('pill-toggle__btn--active');
            if (pillAdd) pillAdd.classList.remove('pill-toggle__btn--active');
        }

        // Back button
        document.getElementById('btnBackToStudents')?.addEventListener('click', hideStudentDetail);

