        document.getElementById('studentsTableBody')?.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-action]');
            if (!btn) return;

            const action = btn.dataset.action;
            const id = btn.dataset.id;

            switch (action) {
                case 'detail': showStudentDetail(id); break;
            }
        });

